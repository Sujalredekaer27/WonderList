   #filters {
  display: flex;
  align-items: center;
  padding: 0.5rem 1.5rem;
  background-color: #fff;
  border-bottom: 1px solid #ebebeb;
}

.filter-options {
  display: flex;
  overflow-x: auto; /* Enables horizontal scrolling */
  flex-grow: 1;
  align-items: center;
}

/* Hide scrollbar for Chrome/Safari */
.filter-options::-webkit-scrollbar {
  display: none;
}

.filter {
  text-align: center;
  margin-right: 2rem;
  margin-top: 1rem;
  opacity: 0.7;
  cursor: pointer;
  min-width: fit-content; /* Prevents text from wrapping */
}

.filter:hover {
  opacity: 1;
  border-bottom: 2px solid black;
}

.filter p {
  font-size: 0.75rem;
  margin-top: 0.2rem;
}

.tax-toggle {
  border: 1px solid rgba(0, 0, 0, 0.2);
  border-radius: 12px;
  height: 3rem;
  padding: 0 1rem;
  margin-left: 2rem;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

/* On small screens, we might want to hide the tax label or the toggle */
@media (max-width: 992px) {
  .tax-toggle {
    display: none; /* Usually hidden on mobile to prioritize filters */
  }
}
</style>
